{
  "name": "@smartpay/routing-srv",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "prebuild": "pnpm db:generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "pnpm --dir ../.. test:spec -- tests/unit/routing-engine.test.ts tests/unit/payment-outcome-consumer.test.ts tests/unit/psp-health-poller.test.ts",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@smartpay/shared": "workspace:*",
    "express": "^5.1.0",
    "ioredis": "^5.8.1",
    "mongodb": "^6.20.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "prisma": "^6.19.2"
  }
}
