generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("MERCHANT_DATABASE_URL")
  schemas  = ["merchants_schema"]
}

model Merchant {
  id        String         @id @default(uuid()) @db.Uuid
  name      String         @db.VarChar(255)
  email     String         @unique @db.VarChar(255)
  status    MerchantStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  apiKeys   ApiKey[]

  @@map("merchants")
  @@schema("merchants_schema")
}

model ApiKey {
  id            String       @id @default(uuid()) @db.Uuid
  merchantId    String       @db.Uuid
  merchant      Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  publicKey     String       @unique @db.VarChar(100)
  secretKeyHash String       @db.VarChar(255)
  status        ApiKeyStatus @default(ACTIVE)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())

  @@index([publicKey])
  @@index([merchantId])
  @@map("api_keys")
  @@schema("merchants_schema")
}

enum MerchantStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED

  @@schema("merchants_schema")
}

enum ApiKeyStatus {
  ACTIVE
  DEPRECATED
  REVOKED

  @@schema("merchants_schema")
}
