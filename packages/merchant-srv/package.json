{
  "name": "@smartpay/merchant-srv",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "prebuild": "pnpm db:generate",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "pnpm --dir ../.. test:spec -- tests/integration/payment-flow.test.ts",
    "db:generate": "node ../../scripts/link-prisma-client.mjs merchant-srv installed && pnpm exec prisma generate --schema prisma/schema.prisma && node ../../scripts/link-prisma-client.mjs merchant-srv generated merchant-client",
    "db:migrate": "pnpm exec prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@smartpay/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "express": "^5.1.0",
    "mongodb": "^6.19.0",
    "nanoid": "^5.1.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.3",
    "prisma": "^6.16.2"
  }
}
