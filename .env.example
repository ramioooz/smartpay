# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=smartpay_admin
POSTGRES_PASSWORD=smartpay_dev_password
POSTGRES_DB=smartpay

# PgBouncer
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432

# Per-Service Database Users
PAYMENT_DB_USER=payment_srv_user
PAYMENT_DB_PASSWORD=payment_srv_password
MERCHANT_DB_USER=merchant_srv_user
MERCHANT_DB_PASSWORD=merchant_srv_password
ROUTING_DB_USER=routing_srv_user
ROUTING_DB_PASSWORD=routing_srv_password

# MongoDB
MONGO_URI=mongodb://mongodb:27017/smartpay

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=kafka:29092

# Service Ports
NGINX_PORT=3000
PAYMENT_SRV_PORT=3001
FX_SRV_PORT=3002
MERCHANT_SRV_PORT=3003
ROUTING_SRV_PORT=3004
RECONCILIATION_SRV_PORT=3005

# JWT
JWT_SECRET=change-this-in-production

# PSP Keys (stubs)
STRIPE_API_KEY=sk_test_stub_not_real
WISE_API_KEY=wise_test_stub_not_real
CHECKOUT_API_KEY=ck_test_stub_not_real

# FX Rate Provider
FX_PRIMARY_PROVIDER=frankfurter
FX_FALLBACK_PROVIDER=simulated
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v1
FX_RATE_REFRESH_INTERVAL_MS=5000
FX_RATE_CACHE_TTL_SECONDS=30
